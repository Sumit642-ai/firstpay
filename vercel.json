{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://headstone-lard-remote.ngrok-free.dev/api/$1"
    },
    {
      "src": "/UploadFiles/(.*)",
      "dest": "https://headstone-lard-remote.ngrok-free.dev/UploadFiles/$1"
    },
    {
      "src": "/Content/MergedFiles/(.*)",
      "dest": "https://headstone-lard-remote.ngrok-free.dev/Content/MergedFiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/package.json"
    }
  ]
}
